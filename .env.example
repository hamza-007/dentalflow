# DentalFlow — environment template.
# Copy this file to .env and replace EVERY value below with your own.
# These are example placeholders only — never use them as-is in any real env.

# ───────── PostgreSQL ─────────
POSTGRES_USER=example_user
POSTGRES_PASSWORD=example_password_change_me
POSTGRES_DB=dentalflow_example
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Connection string used by the Go API (pgxpool). Must match the values above.
DATABASE_URL=postgres://example_user:example_password_change_me@localhost:5432/dentalflow_example?sslmode=disable

# ───────── API (Go) ─────────
API_PORT=8080
API_ENV=development
LOG_LEVEL=info
# Comma-separated origins allowed by the CORS middleware.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ───────── Auth / JWT ─────────
# Generate strong secrets, e.g. `openssl rand -hex 32`. Do NOT reuse these.
JWT_ACCESS_SECRET=example-access-secret-replace-me-aaaaaaaaaaaaaaaa
JWT_REFRESH_SECRET=example-refresh-secret-replace-me-bbbbbbbbbbbbbbbb
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# ───────── File uploads ─────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ───────── Web (Next.js) ─────────
# Base URL the frontend uses to reach the API.
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# ───────── Prosthesis Studio (V2) ─────────
# No keys needed — the fiche de fabrication is assembled deterministically from
# the curated knowledge base (no LLM / no embedding API).
